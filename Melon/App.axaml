<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:local="clr-namespace:Melon"
             x:Class="Melon.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

	<!--<Application.DataTemplates>
		<local:ViewLocator/>
	</Application.DataTemplates>-->
	
    <Application.Styles>
        <FluentTheme />
		<StyleInclude Source="Common/Styles/AppDefaultStyles.axaml"/>
    </Application.Styles>

	<Application.Resources>
		<SolidColorBrush x:Key="PrimaryBackground">#2e3440</SolidColorBrush>
		<SolidColorBrush x:Key="PrimaryForeground">#d8dee9</SolidColorBrush>
		<SolidColorBrush x:Key="HighlightedForeground">#e5e9f0</SolidColorBrush>
		<SolidColorBrush x:Key="PrimaryHoverBackground">#3b4252</SolidColorBrush>
		<SolidColorBrush x:Key="PrimaryHoverForeground">#e5e9f0</SolidColorBrush>

		<FontFamily x:Key="FontAwesome">/Assets/Fonts/fontawesome/Font Awesome 6 Free-Solid-900.otf#Font Awesome 6 Free Solid</FontFamily>
	</Application.Resources>
</Application>
