<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:feat="clr-namespace:Melon.Features.Libraries.LoadLibraryList"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Melon.Features.Libraries.LoadLibraryList.LibraryListView"
			 x:DataType="feat:LibraryListViewModel">

	<Design.DataContext>
		<feat:LibraryListViewModel/>
	</Design.DataContext>
	
	
    <ListBox ItemsSource="{Binding Paths}"/>
</UserControl>
